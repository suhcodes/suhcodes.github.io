---
interface Props {
  show: boolean;
}
const { show } = Astro.props;
---

{
  show && (
    <div
      role="note"
      aria-label="Draft notice"
      class="mb-6 rounded-md border border-yellow-400 bg-yellow-50 px-4 py-3 text-sm text-yellow-800 dark:border-yellow-500/50 dark:bg-yellow-900/20 dark:text-yellow-300"
    >
      ⚠️ This post is a rough draft — formatting in progress.
    </div>
  )
}
