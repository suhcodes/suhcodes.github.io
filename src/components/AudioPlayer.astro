---
interface Props {
  voice: "neutral" | "narrative";
}
const { voice } = Astro.props;
---

<div class="my-6" data-audio-player data-voice={voice}>
  <button
    id="tts-btn"
    class="inline-flex items-center gap-2 rounded-md border border-accent px-4 py-2 text-sm font-medium text-accent transition hover:bg-accent hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
    aria-label="Listen to this post"
  >
    <span aria-hidden="true">🔊</span>
    <span id="tts-btn-label">Listen</span>
  </button>
  <div id="tts-audio-container" class="mt-3 hidden">
    <audio id="tts-audio" controls class="w-full">
      Your browser does not support the audio element.
    </audio>
  </div>
</div>

<script is:inline>
  const btn = document.getElementById("tts-btn");
  const label = document.getElementById("tts-btn-label");
  const container = document.getElementById("tts-audio-container");
  const audioEl = document.getElementById("tts-audio");
  const player = document.querySelector("[data-audio-player]");

  btn?.addEventListener("click", async () => {
    const voice = player?.dataset.voice ?? "neutral";

    // Extract full text from the article element
    const article = document.getElementById("article");
    const text = article ? article.innerText.trim() : "";

    if (!text) {
      label.textContent = "No content found";
      return;
    }

    label.textContent = "Loading…";
    btn.disabled = true;

    try {
      const res = await fetch("/.netlify/functions/tts", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ text, voice }),
      });

      if (!res.ok) throw new Error("TTS request failed");

      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      audioEl.src = url;
      container.classList.remove("hidden");
      audioEl.play();
      label.textContent = "Playing";
    } catch {
      label.textContent = "Error — try again";
      btn.disabled = false;
    }
  });
</script>
